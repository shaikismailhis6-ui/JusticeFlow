{
  "entities": {
    "User": {
      "title": "User",
      "description": "Judicial officer or staff profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "Full name of the officer" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["judge", "clerk", "admin"] },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "Case": {
      "title": "Case",
      "description": "Legal case file",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed", "archived"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "userId"]
    },
    "Document": {
      "title": "Document",
      "description": "Evidence document associated with a case",
      "type": "object",
      "properties": {
        "caseId": { "type": "string" },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "type": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["caseId", "fileName", "fileUrl", "type", "userId"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "AI analysis of a document",
      "type": "object",
      "properties": {
        "documentId": { "type": "string" },
        "summary": { "type": "string" },
        "timeline": { "type": "array" },
        "evidence_audit": { "type": "array" },
        "legal_points": { "type": "array" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["documentId", "summary", "userId"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Chat message for document-specific Q&A",
      "type": "object",
      "properties": {
        "documentId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["documentId", "role", "content", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/cases/{caseId}": {
      "schema": "Case",
      "description": "Legal cases"
    },
    "/documents/{documentId}": {
      "schema": "Document",
      "description": "Evidence documents"
    },
    "/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "Document analyses"
    },
    "/chats/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat history"
    }
  }
}
